{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "transcript.schema.json",
  "title": "Timestamped transcript",
  "type": "object",
  "required": ["version", "asset_id", "language", "segments"],
  "properties": {
    "version": { "type": "string" },
    "asset_id": { "type": "string" },
    "language": { "type": "string" },
    "segments": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["start", "end", "text", "speaker", "confidence", "words"],
        "properties": {
          "start": { "type": "number", "minimum": 0 },
          "end": { "type": "number", "minimum": 0 },
          "text": { "type": "string" },
          "speaker": { "type": ["string", "null"] },
          "confidence": {
            "type": ["number", "null"],
            "minimum": 0,
            "maximum": 1
          },
          "words": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["start", "end", "text", "confidence"],
              "properties": {
                "start": { "type": "number", "minimum": 0 },
                "end": { "type": "number", "minimum": 0 },
                "text": { "type": "string" },
                "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
              }
            }
          }
        }
      }
    }
  }
}
