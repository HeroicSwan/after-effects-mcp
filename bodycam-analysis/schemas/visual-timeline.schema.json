{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "visual-timeline.schema.json",
  "title": "Multimodal video timeline",
  "type": "object",
  "required": ["version", "asset_id", "events"],
  "properties": {
    "version": { "type": "string" },
    "job_id": { "type": "string" },
    "asset_id": { "type": "string" },
    "source_path": { "type": "string" },
    "generated_at": { "type": "string", "format": "date-time" },
    "duration_seconds": { "type": "number", "minimum": 0 },
    "analyzer": { "type": "object" },
    "summary": { "type": "object" },
    "events": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "start",
          "end",
          "event_type",
          "description",
          "evidence",
          "confidence",
          "review_required"
        ],
        "properties": {
          "event_id": { "type": "string" },
          "start": { "type": "number", "minimum": 0 },
          "end": { "type": "number", "minimum": 0 },
          "event_type": {
            "enum": [
              "scene",
              "speech",
              "sound",
              "action",
              "privacy",
              "quality",
              "editorial"
            ]
          },
          "description": { "type": "string" },
          "evidence": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 1
          },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "review_required": { "type": "boolean" },
          "source": { "type": "string" }
        }
      }
    },
    "review": { "type": "object" }
  }
}
